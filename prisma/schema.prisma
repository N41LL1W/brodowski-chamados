generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Role {
  id    Int     @id @default(autoincrement())
  name  String? @unique
  users User[]
}

model Level {
  id    Int     @id @default(autoincrement())
  name  String? @unique
  rank  Int?    @default(1)
  users User[]
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  passwordHash    String?
  emailVerified   DateTime?
  image           String?
  role            String    @default("FUNCIONARIO")
  active          Boolean   @default(true)
  roleId          Int?
  levelId         Int?
  accounts        Account[]
  comments        Comment[]
  sessions        Session[]
  assignedTickets Ticket[]  @relation("AssignedTo")
  tickets         Ticket[]  @relation("CreatedBy")
  levelRelation   Level?    @relation(fields: [levelId], references: [id])
  roleRelation    Role?     @relation(fields: [roleId], references: [id])
  createdAt       DateTime  @default(now())
}

model Category {
  id      String   @id
  name    String
  icon    String   @default("Wrench")
  tickets Ticket[]
}

model CategoryConfig {
  id     String  @id @default(cuid())
  name   String
  icon   String  @default("Monitor")
  order  Int     @default(0)
  active Boolean @default(true)
}

model Department {
  id      String   @id
  name    String
  tickets Ticket[]
}

model Ticket {
  id           String     @id @default(cuid())
  protocol     String     @unique
  subject      String
  description  String
  status       String     @default("ABERTO")
  priority     String     @default("NORMAL")
  categoryId   String
  departmentId String
  requesterId  String
  assignedToId String?
  createdAt    DateTime   @default(now()) @db.Timestamp(6)
  updatedAt    DateTime   @updatedAt @db.Timestamp(6)
  location     String?
  proofImage   String?
  visitDate    DateTime?
  visitNote    String?
  comments     Comment[]
  assignedTo   User?      @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requester    User       @relation("CreatedBy", fields: [requesterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  createdAt  DateTime @default(now())
  ticketId   String
  userId     String
  proofImage String?
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SLAConfig {
  id       Int    @id @default(autoincrement())
  priority String @unique
  maxHours Int
  label    String
  color    String @default("amber")
}

model SystemConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model RolePermission {
  id          String @id @default(cuid())
  role        String @unique
  permissions String
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String
  details   String
  createdAt DateTime @default(now())
}

model ThemeConfig {
  id    String @id @default(cuid())
  theme String // "light" ou "dark"
  key   String
  value String
  @@unique([theme, key])
}

model NotificationConfig {
  id      String  @id @default(cuid())
  event   String  @unique
  label   String
  enabled Boolean @default(true)
  roles   String  // JSON array de roles
}

model CustomField {
  id       String  @id @default(cuid())
  name     String
  label    String
  type     String  @default("text") // text, select, number, textarea
  options  String? // JSON array para type=select
  required Boolean @default(false)
  active   Boolean @default(true)
  order    Int     @default(0)
}

model BusinessHours {
  id        String @id @default(cuid())
  dayOfWeek Int    @unique // 0=Dom, 1=Seg...6=Sab
  open      Boolean @default(true)
  startTime String  @default("08:00")
  endTime   String  @default("17:00")
}

model AutoMessage {
  id      String @id @default(cuid())
  trigger String @unique // TICKET_OPENED, TICKET_ASSIGNED, etc
  label   String
  content String
  active  Boolean @default(true)
}

model TermsOfUse {
  id        String   @id @default(cuid())
  content   String
  version   String
  updatedAt DateTime @updatedAt
}